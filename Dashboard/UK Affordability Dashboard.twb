      <column caption='Latest Year' datatype='integer' name='[Calculation_4196137235701760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF TRIM([Series_Type]) = &quot;Historical&quot; THEN [Year] END) }' />
      </column>
      <column caption='Latest UK Affordability' datatype='real' name='[Calculation_4196137236058113]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Year] = [Calculation_4196137235701760]&#10;AND TRIM([Series_Type]) = &quot;Historical&quot;&#10;THEN [Value]&#10;END' />
      </column>
      <column caption='5-Year Change' datatype='real' name='[Calculation_4196137236209666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_4196137246236683] - [Calculation_4196137246355468]) &#10;/ &#10;[Calculation_4196137246355468]' />
      </column>
      <column caption='Most Unaffordable Region' datatype='string' name='[Calculation_4196137236369411]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED : MAX(&#10;    IF [Year] = [Calculation_4196137235701760]&#10;    AND TRIM([Series_Type]) = &quot;Historical&quot;&#10;    AND [Value] = [Calculation_4196137247903758]&#10;    THEN [Region name] END&#10;)}' />
      </column>
      <column caption='Least Unaffordable Region' datatype='string' name='[Calculation_4196137236635652]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED : MAX(&#10;    IF [Year] = [Calculation_4196137235701760]&#10;    AND TRIM([Series_Type]) = &quot;Historical&quot;&#10;    AND [Value] = [Calculation_4196137248002063]&#10;    THEN [Region name] END&#10;)}' />
      </column>
      <column caption='Forecast 2029' datatype='real' name='[Calculation_4196137240186886]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Year] = 2029 &#10;AND [Series_Type] = &quot;Forecast&quot; &#10;THEN [Value] &#10;END' />
      </column>
      <column caption='Value Latest Year' datatype='real' name='[Calculation_4196137246236683]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Region name] : &#10;    AVG(IF [Year] = [Calculation_4196137235701760] &#10;    AND TRIM([Series_Type]) = &quot;Historical&quot; &#10;    THEN [Value] END) &#10;}' />
      </column>
      <column caption='Value 5 Years Ago' datatype='real' name='[Calculation_4196137246355468]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Region name] : &#10;    AVG(IF [Year] = [Calculation_4196137235701760] - 5&#10;    AND TRIM([Series_Type]) = &quot;Historical&quot; &#10;    THEN [Value] END) &#10;}' />
      </column>
      <column caption='Max Affordability Value' datatype='real' name='[Calculation_4196137247903758]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(&#10;    IF [Year] = [Calculation_4196137235701760]&#10;    AND TRIM([Series_Type]) = &quot;Historical&quot;&#10;    THEN [Value] END&#10;)}' />
      </column>
      <column caption='Min Affordability Value' datatype='real' name='[Calculation_4196137248002063]' role='measure' type='quantitative'>
