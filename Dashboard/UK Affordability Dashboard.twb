              <calculation class='tableau' formula='([Calculation_4196137246236683] - [Calculation_4196137246355468]) &#10;/ &#10;[Calculation_4196137246355468]' />
            </column>
            <column caption='Most Unaffordable Region' datatype='string' name='[Calculation_4196137236369411]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED : MAX(&#10;    IF [Year] = [Calculation_4196137235701760]&#10;    AND TRIM([Series_Type]) = &quot;Historical&quot;&#10;    AND [Value] = [Calculation_4196137247903758]&#10;    THEN [Region name] END&#10;)}' />
