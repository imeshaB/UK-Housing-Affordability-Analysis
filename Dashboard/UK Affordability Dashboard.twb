            <column caption='Latest Year' datatype='integer' name='[Calculation_4196137235701760]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF TRIM([Series_Type]) = &quot;Historical&quot; THEN [Year] END) }' />
            </column>
